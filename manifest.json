{
  "manifest_version": 3,
  "name": "Free Tracking",
  "version": "1.0.0",
  "description": "Import tracking numbers, fetch USPS status, and export the results to Excel.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Free Tracking",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "scripting", "downloads", "alarms"],
  "host_permissions": ["https://tools.usps.com/*"],
  "content_scripts": [
    {
      "matches": ["https://tools.usps.com/tracking/*"],
      "js": ["dist/content/usps-content.js"],
      "run_at": "document_idle"
    }
  ]
}
